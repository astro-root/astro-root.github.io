{
  "_meta": {
    "version": "1.0.0",
    "schema": "study",
    "description": "Studyコンテンツデータ。Firebase Firestoreコレクション 'study_items' への移行を想定。",
    "firestore": {
      "collection": "study_items",
      "indexFields": ["category", "status", "publishedAt", "difficulty"],
      "orderBy": [["category", "asc"], ["publishedAt", "desc"]]
    },
    "changelog": [
      { "version": "1.0.0", "date": "2026-06-28", "note": "初期スキーマ定義" }
    ]
  },
  "_schema": {
    "id":            "string  — Firestoreドキュメントid（slug形式）",
    "title":         "string  — コンテンツタイトル",
    "slug":          "string  — URLスラッグ",
    "category":      "string  — 'physics' | 'astronomy' | 'mathematics' | 'simulations'",
    "subcategory":   "string  — サブカテゴリ（例: 'mechanics', 'electromagnetism'）",
    "excerpt":       "string  — 要約（100字以内）",
    "body":          "string  — 本文（Markdown形式）",
    "difficulty":    "number  — 難易度 1〜5",
    "status":        "string  — 'published' | 'draft' | 'wip'",
    "publishedAt":   "string  — ISO 8601日時文字列",
    "updatedAt":     "string  — ISO 8601日時文字列",
    "tags":          "string[] — タグ一覧",
    "references":    "object[] — 参考文献 { title, url, author }",
    "simulation":    "object | null — シミュレーション設定（simulationsカテゴリのみ）",
    "simulation.type":      "'canvas' | 'webgl' | 'iframe'",
    "simulation.scriptSrc": "string — JSファイルパス（assetsからの相対パス）",
    "simulation.params":    "object — シミュレーション初期パラメータ",
    "coverImage":    "string | null — サムネイル画像パス",
    "featured":      "boolean — 特集表示フラグ"
  },
  "categories": [
    {
      "id":          "physics",
      "label":       "Physics",
      "labelJa":     "物理学",
      "color":       "#3b9eff",
      "description": "力学・電磁気学・量子力学・熱力学・相対性理論などの物理学ノート",
      "subcategories": [
        { "id": "mechanics",        "label": "Mechanics",         "labelJa": "力学" },
        { "id": "electromagnetism", "label": "Electromagnetism",  "labelJa": "電磁気学" },
        { "id": "thermodynamics",   "label": "Thermodynamics",    "labelJa": "熱力学" },
        { "id": "quantum",          "label": "Quantum Mechanics", "labelJa": "量子力学" },
        { "id": "relativity",       "label": "Relativity",        "labelJa": "相対性理論" }
      ]
    },
    {
      "id":          "astronomy",
      "label":       "Astronomy",
      "labelJa":     "天文学",
      "color":       "#00e5b8",
      "description": "天体観測・宇宙論・銀河・恒星進化・惑星科学などの天文学ノート",
      "subcategories": [
        { "id": "cosmology",   "label": "Cosmology",     "labelJa": "宇宙論" },
        { "id": "stellar",     "label": "Stellar",        "labelJa": "恒星進化" },
        { "id": "galaxies",    "label": "Galaxies",       "labelJa": "銀河" },
        { "id": "planetary",   "label": "Planetary",      "labelJa": "惑星科学" },
        { "id": "observation", "label": "Observation",    "labelJa": "天体観測" }
      ]
    },
    {
      "id":          "mathematics",
