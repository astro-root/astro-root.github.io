      "labelJa":     "数学",
      "color":       "#8b72ff",
      "description": "解析学・線形代数・確率統計・微分方程式などの数学ノート",
      "subcategories": [
        { "id": "calculus",      "label": "Calculus",           "labelJa": "微積分学" },
        { "id": "linear-algebra","label": "Linear Algebra",     "labelJa": "線形代数" },
        { "id": "statistics",    "label": "Statistics",         "labelJa": "確率統計" },
        { "id": "differential",  "label": "Differential Eq.",   "labelJa": "微分方程式" },
        { "id": "number-theory", "label": "Number Theory",      "labelJa": "数論" }
      ]
    },
    {
      "id":          "simulations",
      "label":       "Simulations",
      "labelJa":     "シミュレーション",
      "color":       "#ffb340",
      "description": "JavaScript / TypeScript による物理・天文学インタラクティブシミュレーション",
      "subcategories": [
        { "id": "orbital",    "label": "Orbital Mechanics", "labelJa": "軌道力学" },
        { "id": "n-body",     "label": "N-Body Problem",    "labelJa": "多体問題" },
        { "id": "wave",       "label": "Wave",              "labelJa": "波動" },
        { "id": "fluid",      "label": "Fluid Dynamics",    "labelJa": "流体力学" },
        { "id": "custom",     "label": "Custom",            "labelJa": "その他" }
      ]
    }
  ],
  "items": []
}
