      { "version": "1.0.0", "date": "2026-06-28", "note": "初期スキーマ定義・既存ツール7件を登録" }
    ]
  },
  "_schema": {
    "id":          "string  — Firestoreドキュメントid（kebab-case）",
    "category":    "string  — カテゴリid",
    "name":        "string  — プロジェクト名",
    "nameEn":      "string  — 英語名",
    "description": "string  — 説明文（日本語）",
    "descriptionEn":"string — 説明文（英語）",
    "url":         "string  — 公開URL",
    "repoUrl":     "string | null — GitHubリポジトリURL",
    "status":      "string  — 'active' | 'beta' | 'maintenance' | 'archived' | 'wip'",
    "tags":        "string[] — 技術タグ",
    "room":        "string  — 部屋番号（RM-XXX形式）",
    "order":       "number  — カテゴリ内表示順",
    "featured":    "boolean — トップ特集表示フラグ",
    "coverImage":  "string | null — プロジェクトサムネイル",
    "publishedAt": "string  — ISO 8601日時文字列（公開日）",
    "updatedAt":   "string  — ISO 8601日時文字列（最終更新日）",
    "metrics":     "object | null — メトリクス { stars, users, version }",
    "relatedIds":  "string[] — 関連プロジェクトid一覧"
  },
