{
  "_meta": {
    "version": "1.0.0",
    "schema": "project",
    "description": "公開プロジェクト・Webツールデータ。Firebase Firestoreコレクション 'projects' への移行を想定。",
    "firestore": {
      "collection": "projects",
      "indexFields": ["category", "status", "order"],
      "orderBy": [["category", "asc"], ["order", "asc"]]
    },
